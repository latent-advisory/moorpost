{
  "name": "moorpost-vscode",
  "displayName": "Moorpost VSCode",
  "description": "Tether your laptop to a remote forward base where Claude Code keeps working.",
  "version": "1.1.11",
  "publisher": "LatentAdvisory",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0E1116",
    "theme": "dark"
  },
  "homepage": "https://github.com/latent-advisory/moorpost",
  "repository": {
    "type": "git",
    "url": "https://github.com/latent-advisory/moorpost.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "remote",
    "tmux",
    "gcp"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.moorpost/config.yaml",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "moorpost.bootstrap",
        "title": "Moorpost: Bootstrap (one-shot setup)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.runSetup",
        "title": "Moorpost: Install prerequisites (setup)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.runDoctor",
        "title": "Moorpost: Run doctor (diagnostics)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.initProject",
        "title": "Moorpost: Initialize project (choose folder)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.signIn",
        "title": "Moorpost: Sign in (claude OAuth)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.provision",
        "title": "Moorpost: Provision VM",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.handoff",
        "title": "Moorpost: Handoff to remote",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.return",
        "title": "Moorpost: Return to local",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.status",
        "title": "Moorpost: Show status",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.refreshTree",
        "title": "Refresh",
        "category": "Moorpost",
        "icon": "$(refresh)"
      },
      {
        "command": "moorpost.showConflicts",
        "title": "Moorpost: Show sync conflicts",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.showSessions",
        "title": "Moorpost: Show sessions (local + remote)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.returnSession",
        "title": "Moorpost: Return this session to local",
        "icon": "$(arrow-down)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.openRemoteSession",
        "title": "Moorpost: Open remote session",
        "icon": "$(link-external)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.debugSessionTracker",
        "title": "Moorpost: Debug session tracker",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.attach",
        "title": "Moorpost: Attach to remote tmux",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.destroy",
        "title": "Moorpost: Destroy VM…",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.showCost",
        "title": "Moorpost: Show cost details",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.toggleSide",
        "title": "Moorpost: Switch local ↔ remote",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.editConfig",
        "title": "Moorpost: Edit project config (machine type, region, sync)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.stopVm",
        "title": "Moorpost: Stop VM (preserves disk)",
        "icon": "$(debug-stop)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.startVm",
        "title": "Moorpost: Start VM",
        "icon": "$(play)",
        "category": "Moorpost"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moorpost",
          "title": "Moorpost",
          "icon": "$(cloud)"
        }
      ]
    },
    "views": {
      "moorpost": [
        {
          "id": "moorpost.projectTree",
          "name": "Project",
          "contextualTitle": "Moorpost"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "moorpost.projectTree",
        "contents": "No Moorpost project here yet.\n\nMoorpost lets you hand off Claude Code sessions between your laptop and a remote VM.\n\n[Bootstrap](command:moorpost.bootstrap)\n\nOne-shot setup: prereqs, sign-in, project init, and (optionally) the VM. Skips work that's already done."
      }
    ],
    "walkthroughs": [
      {
        "id": "moorpost.gettingStarted",
        "title": "Get started with Moorpost",
        "description": "One click. Bootstrap installs prereqs, signs you in, initializes the project, and (optionally) provisions the VM.",
        "steps": [
          {
            "id": "bootstrap",
            "title": "Bootstrap (one-shot)",
            "description": "$(rocket) Click below. The wizard asks which folder to manage and whether to also provision a remote VM, then handles everything.\n\n[Bootstrap](command:moorpost.bootstrap)\n\nUnder the hood: detects missing prereqs and installs them via brew/apt, opens a browser for the Claude OAuth flow (~30s), writes `.moorpost/config.yaml`, and (if you said yes) provisions a GCE VM. Skips work that's already done.",
            "media": {
              "markdown": "media/walkthrough/bootstrap.md"
            }
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "moorpost.refreshTree",
          "when": "false"
        },
        {
          "command": "moorpost.initProject",
          "when": "false"
        },
        {
          "command": "moorpost.runSetup",
          "when": "false"
        },
        {
          "command": "moorpost.signIn",
          "when": "false"
        },
        {
          "command": "moorpost.handoff",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.return",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.toggleSide",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.provision",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.attach",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.destroy",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.showCost",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.showConflicts",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.editConfig",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.stopVm",
          "when": "moorpost.configured"
        },
        {
          "command": "moorpost.startVm",
          "when": "moorpost.configured"
        }
      ],
      "view/title": [
        {
          "command": "moorpost.refreshTree",
          "when": "view == moorpost.projectTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "moorpost.handoff",
          "when": "view == moorpost.projectTree && viewItem == moorpost.activeSide.local",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.return",
          "when": "view == moorpost.projectTree && viewItem == moorpost.activeSide.remote",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.return",
          "when": "view == moorpost.projectTree && viewItem == moorpost.remoteSessionsRoot",
          "group": "moorpost@1",
          "title": "Return..."
        },
        {
          "command": "moorpost.returnSession",
          "when": "view == moorpost.projectTree && viewItem == moorpost.remoteSession",
          "group": "inline"
        },
        {
          "command": "moorpost.attach",
          "when": "view == moorpost.projectTree && viewItem =~ /^moorpost\\.vm/",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.stopVm",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm.running",
          "group": "inline"
        },
        {
          "command": "moorpost.stopVm",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm.running",
          "group": "moorpost@2"
        },
        {
          "command": "moorpost.startVm",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm.stopped",
          "group": "inline"
        },
        {
          "command": "moorpost.startVm",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm.stopped",
          "group": "moorpost@2"
        },
        {
          "command": "moorpost.destroy",
          "when": "view == moorpost.projectTree && viewItem =~ /^moorpost\\.vm/",
          "group": "moorpost@9"
        },
        {
          "command": "moorpost.showCost",
          "when": "view == moorpost.projectTree && viewItem == moorpost.cost",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.showConflicts",
          "when": "view == moorpost.projectTree && viewItem == moorpost.conflicts",
          "group": "moorpost@1"
        }
      ]
    },
    "configuration": {
      "title": "Moorpost",
      "properties": {
        "moorpost.cliPath": {
          "type": "string",
          "default": "moorpost",
          "description": "Path to the moorpost CLI binary (default: search PATH)."
        },
        "moorpost.statusBarRefreshSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "description": "How often to refresh the status bar by calling `moorpost status`. Action-driven refreshes (after handoff, return, etc.) happen immediately regardless of this interval."
        },
        "moorpost.promptOnFocusLossMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Show a 'hand off to remote?' prompt after the VSCode window has been unfocused for this many minutes. Set to 0 to disable."
        },
        "moorpost.promptOnIdleMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "description": "Show a 'hand off to remote?' prompt after this many minutes of editor inactivity. Also fires when the OS appears to wake from sleep. Set to 0 to disable."
        },
        "moorpost.autoAttachOnHandoff": {
          "type": "boolean",
          "default": true,
          "description": "After a successful Handoff, automatically open an integrated terminal attached to the remote Claude session. Disable if you prefer to attach manually."
        },
        "moorpost.autoMigrateOnHandoff": {
          "type": "boolean",
          "default": false,
          "description": "When Handoff swaps the plugin surface, skip the 'Migrate this conversation?' prompt and silently open a fresh chat on the remote VM that resumes the prior session. The model retains full context; the plugin panel scrollback resets (prior messages remain in Claude Code's history list). Off by default — the prompt is shown so the scrollback reset is opt-in per handoff."
        },
        "moorpost.autoStopWhenNoRemoteSessions": {
          "type": "boolean",
          "default": true,
          "description": "Automatically stop the project's VM when no sessions are routed to remote. Catches the rare case where the previous return's stop request was rejected (network blip, GCE fingerprint race) or state reached this configuration via a path that bypassed the return CLI's stop hook. Throttled to once per 90s so we don't fire repeated stops while the previous async stop is still mid-transition. Set to false to keep the VM warm for quick subsequent handoffs."
        },
        "moorpost.handoffSurface": {
          "type": "string",
          "enum": [
            "auto",
            "terminal",
            "plugin"
          ],
          "enumDescriptions": [
            "Detect from current state — terminal if a Moorpost: Claude terminal is open, plugin if the Anthropic Claude Code plugin is installed and routed, otherwise terminal.",
            "Always swap the Moorpost: Claude terminal; never touch the Anthropic Claude Code plugin's wrapper.",
            "Always re-route the Anthropic Claude Code plugin's panel; never spawn a Moorpost: Claude terminal."
          ],
          "default": "auto",
          "description": "Which surface Handoff and Return should swap (terminal, plugin panel, or auto-detect). Use this if 'auto' picks the wrong surface for your workflow."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "node esbuild.js --production",
    "test": "node --experimental-transform-types --disable-warning=ExperimentalWarning --import ./test/loader-register.mjs --test 'src/**/*.test.mts'"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.21.0",
    "typescript": "^5.3.0"
  }
}

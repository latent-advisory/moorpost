{
  "name": "moorpost",
  "displayName": "Moorpost",
  "description": "Tether your laptop to a remote forward base where Claude Code keeps working.",
  "version": "1.0.0",
  "publisher": "latent-advisory",
  "license": "Apache-2.0",
  "homepage": "https://github.com/latent-advisory/moorpost",
  "repository": {
    "type": "git",
    "url": "https://github.com/latent-advisory/moorpost.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "remote",
    "tmux",
    "gcp"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.moorpost/config.yaml",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "moorpost.bootstrap",
        "title": "Moorpost: Bootstrap (one-shot setup)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.runSetup",
        "title": "Moorpost: Install prerequisites (setup)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.runDoctor",
        "title": "Moorpost: Run doctor (diagnostics)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.initProject",
        "title": "Moorpost: Initialize project (choose folder)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.signIn",
        "title": "Moorpost: Sign in (claude OAuth)",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.provision",
        "title": "Moorpost: Provision VM",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.handoff",
        "title": "Moorpost: Handoff to remote",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.return",
        "title": "Moorpost: Return to local",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.status",
        "title": "Moorpost: Show status",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.refreshTree",
        "title": "Refresh",
        "category": "Moorpost",
        "icon": "$(refresh)"
      },
      {
        "command": "moorpost.showConflicts",
        "title": "Moorpost: Show sync conflicts",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.attach",
        "title": "Moorpost: Attach to remote tmux",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.destroy",
        "title": "Moorpost: Destroy VM…",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.showCost",
        "title": "Moorpost: Show cost details",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.toggleSide",
        "title": "Moorpost: Switch local ↔ remote",
        "category": "Moorpost"
      },
      {
        "command": "moorpost.editConfig",
        "title": "Moorpost: Edit project config (machine type, region, sync)",
        "category": "Moorpost"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moorpost",
          "title": "Moorpost",
          "icon": "$(cloud)"
        }
      ]
    },
    "views": {
      "moorpost": [
        {
          "id": "moorpost.projectTree",
          "name": "Project",
          "contextualTitle": "Moorpost"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "moorpost.projectTree",
        "contents": "No Moorpost project here yet.\n\nMoorpost lets you hand off Claude Code sessions between your laptop and a remote VM.\n\n[Bootstrap](command:moorpost.bootstrap)\n\nOne-shot setup: prereqs, sign-in, project init, and (optionally) the VM. Skips work that's already done."
      }
    ],
    "walkthroughs": [
      {
        "id": "moorpost.gettingStarted",
        "title": "Get started with Moorpost",
        "description": "One click. Bootstrap installs prereqs, signs you in, initializes the project, and (optionally) provisions the VM.",
        "steps": [
          {
            "id": "bootstrap",
            "title": "Bootstrap (one-shot)",
            "description": "$(rocket) Click below. The wizard asks which folder to manage and whether to also provision a remote VM, then handles everything.\n\n[Bootstrap](command:moorpost.bootstrap)\n\nUnder the hood: detects missing prereqs and installs them via brew/apt, opens a browser for the Claude OAuth flow (~30s), writes `.moorpost/config.yaml`, and (if you said yes) provisions a GCE VM. Skips work that's already done.",
            "media": {
              "markdown": "media/walkthrough/bootstrap.md"
            }
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "moorpost.refreshTree", "when": "false" },
        { "command": "moorpost.initProject", "when": "false" },
        { "command": "moorpost.runSetup", "when": "false" },
        { "command": "moorpost.signIn", "when": "false" },
        { "command": "moorpost.handoff", "when": "moorpost.configured" },
        { "command": "moorpost.return", "when": "moorpost.configured" },
        { "command": "moorpost.toggleSide", "when": "moorpost.configured" },
        { "command": "moorpost.provision", "when": "moorpost.configured" },
        { "command": "moorpost.attach", "when": "moorpost.configured" },
        { "command": "moorpost.destroy", "when": "moorpost.configured" },
        { "command": "moorpost.showCost", "when": "moorpost.configured" },
        { "command": "moorpost.showConflicts", "when": "moorpost.configured" },
        { "command": "moorpost.editConfig", "when": "moorpost.configured" }
      ],
      "view/title": [
        {
          "command": "moorpost.refreshTree",
          "when": "view == moorpost.projectTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "moorpost.handoff",
          "when": "view == moorpost.projectTree && viewItem == moorpost.activeSide.local",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.return",
          "when": "view == moorpost.projectTree && viewItem == moorpost.activeSide.remote",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.attach",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.destroy",
          "when": "view == moorpost.projectTree && viewItem == moorpost.vm",
          "group": "moorpost@9"
        },
        {
          "command": "moorpost.showCost",
          "when": "view == moorpost.projectTree && viewItem == moorpost.cost",
          "group": "moorpost@1"
        },
        {
          "command": "moorpost.showConflicts",
          "when": "view == moorpost.projectTree && viewItem == moorpost.conflicts",
          "group": "moorpost@1"
        }
      ]
    },
    "configuration": {
      "title": "Moorpost",
      "properties": {
        "moorpost.cliPath": {
          "type": "string",
          "default": "moorpost",
          "description": "Path to the moorpost CLI binary (default: search PATH)."
        },
        "moorpost.statusBarRefreshSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "description": "How often to refresh the status bar by calling `moorpost status`. Action-driven refreshes (after handoff, return, etc.) happen immediately regardless of this interval."
        },
        "moorpost.promptOnFocusLossMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Show a 'hand off to remote?' prompt after the VSCode window has been unfocused for this many minutes. Set to 0 to disable."
        },
        "moorpost.promptOnIdleMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "description": "Show a 'hand off to remote?' prompt after this many minutes of editor inactivity. Also fires when the OS appears to wake from sleep. Set to 0 to disable."
        },
        "moorpost.autoAttachOnHandoff": {
          "type": "boolean",
          "default": true,
          "description": "After a successful Handoff, automatically open an integrated terminal attached to the remote Claude session. Disable if you prefer to attach manually."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}

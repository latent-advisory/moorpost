#!/usr/bin/env bash
# Moorpost VM bootstrap script (rendered for project: {{.ProjectSlug}})
# Runs once on first VM boot via the provider's startup-script mechanism.
# Idempotent: re-running is a no-op once everything's installed.

set -euo pipefail

# /opt/node/bin holds Node + npm (installed in step 2). Put it on PATH up
# front so npm-installed global binaries (e.g. claude-code in step 3) are
# resolvable by the rest of this script via `command -v`.
export PATH="/opt/node/bin:${PATH}"

LOG=/var/log/moorpost-bootstrap.log
exec > >(tee -a "$LOG") 2>&1

echo "[moorpost] bootstrap starting at $(date -u +%FT%TZ) for project={{.ProjectSlug}}"

# --------------------------------------------------------------------------
# 1. Base packages (apt)
# --------------------------------------------------------------------------
echo "[moorpost] step 1: base packages"
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y --no-install-recommends \
    ca-certificates curl gnupg jq tmux \
    ripgrep fd-find xz-utils \
    git unzip

# `fd-find` installs as `fdfind` on Debian/Ubuntu; symlink for muscle memory.
if [ ! -e /usr/local/bin/fd ] && command -v fdfind >/dev/null 2>&1; then
    ln -s "$(command -v fdfind)" /usr/local/bin/fd
fi

# --------------------------------------------------------------------------
# 2. Node.js {{.NodeVersion}} (official tarball, no NodeSource apt repo)
# --------------------------------------------------------------------------
# Why a tarball instead of NodeSource: the apt-based path (apt-get update
# after adding nodesource → apt-get install nodejs) is the slowest and
# flakiest part of bootstrap. A direct tarball fetch from nodejs.org is one
# ~30MB download, takes ~10-30s on GCE network, and has no apt-mirror
# dependency.
echo "[moorpost] step 2: Node.js {{.NodeVersion}}"
if ! command -v node >/dev/null 2>&1 || \
   [ "$(node --version 2>/dev/null | cut -dv -f2 | cut -d. -f1)" != "{{.NodeVersion}}" ]; then
    case "$(uname -m)" in
        x86_64)  NODE_ARCH=linux-x64 ;;
        aarch64) NODE_ARCH=linux-arm64 ;;
        *) echo "[moorpost] unsupported arch: $(uname -m)"; exit 1 ;;
    esac
    NODE_DIST="https://nodejs.org/dist/latest-v{{.NodeVersion}}.x"
    NODE_TARBALL=$(curl -fsSL "${NODE_DIST}/SHASUMS256.txt" \
        | awk -v a="$NODE_ARCH" '$2 ~ a"\\.tar\\.xz$"{print $2; exit}')
    if [ -z "$NODE_TARBALL" ]; then
        echo "[moorpost] could not resolve node tarball name from $NODE_DIST"; exit 1
    fi
    curl -fsSL "${NODE_DIST}/${NODE_TARBALL}" -o /tmp/node.tar.xz
    install -d -m 0755 /opt/node
    tar -xJf /tmp/node.tar.xz -C /opt/node --strip-components=1
    rm -f /tmp/node.tar.xz
    ln -sf /opt/node/bin/node /usr/local/bin/node
    ln -sf /opt/node/bin/npm  /usr/local/bin/npm
    ln -sf /opt/node/bin/npx  /usr/local/bin/npx
fi

# Make /opt/node/bin available to interactive shells (SSH sessions) and
# systemd units — the bootstrap script's own PATH export is only seen by
# this script's processes.
cat > /etc/profile.d/moorpost-node.sh <<'NODE_PROFILE_EOF'
export PATH="/opt/node/bin:${PATH}"
NODE_PROFILE_EOF
chmod 0644 /etc/profile.d/moorpost-node.sh

echo "[moorpost] node: $(node --version 2>/dev/null || echo MISSING)"

# --------------------------------------------------------------------------
# 3. Claude Code CLI
# --------------------------------------------------------------------------
echo "[moorpost] step 3: Claude Code CLI"
if ! command -v claude >/dev/null 2>&1; then
    npm install -g @anthropic-ai/claude-code{{if .ClaudeCodeVersion}}@{{.ClaudeCodeVersion}}{{end}}
    # npm puts global binaries in /opt/node/bin (already on this script's
    # PATH). Also symlink to /usr/local/bin so the e2e probe and any user
    # whose PATH wasn't refreshed can still find it.
    if [ -e /opt/node/bin/claude ] && [ ! -e /usr/local/bin/claude ]; then
        ln -sf /opt/node/bin/claude /usr/local/bin/claude
    fi
fi
echo "[moorpost] claude: $(claude --version 2>/dev/null || echo MISSING)"

# --------------------------------------------------------------------------
# 4. uv (fast Python package manager)
# --------------------------------------------------------------------------
echo "[moorpost] step 4: uv"
if ! command -v uv >/dev/null 2>&1; then
    # The astral.sh installer drops uv at $HOME/.local/bin/uv. cloud-init
    # runs this script with HOME unset, so use a default and override the
    # installer's HOME to make it deterministic.
    INSTALLER_HOME="${HOME:-/root}"
    HOME="$INSTALLER_HOME" curl -fsSL https://astral.sh/uv/install.sh | HOME="$INSTALLER_HOME" sh
    if [ -f "$INSTALLER_HOME/.local/bin/uv" ] && [ ! -e /usr/local/bin/uv ]; then
        ln -s "$INSTALLER_HOME/.local/bin/uv" /usr/local/bin/uv
    fi
fi

# --------------------------------------------------------------------------
# 5. Project working tree + symlink
# --------------------------------------------------------------------------
echo "[moorpost] step 5: project working tree + abs-path symlink"
REMOTE_HOME="$(getent passwd "{{.RemoteUser}}" | cut -d: -f6)"
if [ -z "$REMOTE_HOME" ]; then
    # Fallback for OS Login users who may not exist yet at first boot.
    REMOTE_HOME="/home/{{.RemoteUser}}"
    mkdir -p "$REMOTE_HOME"
fi
PROJECT_DIR="$REMOTE_HOME/moorpost/{{.ProjectSlug}}"
mkdir -p "$PROJECT_DIR"
chown -R "{{.RemoteUser}}:{{.RemoteUser}}" "$REMOTE_HOME/moorpost"

# The absolute-path symlink is what makes `claude --resume` work seamlessly
# across local and remote — both sides resolve to the same path, so Claude's
# session-state encoding (~/.claude/projects/<encoded>) matches.
LOCAL_ABS_PATH="{{.LocalAbsPath}}"
if [ -n "$LOCAL_ABS_PATH" ]; then
    LOCAL_ABS_PARENT="$(dirname "$LOCAL_ABS_PATH")"
    mkdir -p "$LOCAL_ABS_PARENT"
    if [ -L "$LOCAL_ABS_PATH" ] || [ ! -e "$LOCAL_ABS_PATH" ]; then
        ln -sfn "$PROJECT_DIR" "$LOCAL_ABS_PATH"
    fi
fi

# --------------------------------------------------------------------------
# 6. /etc/moorpost/env (skeleton; populated later by `moorpost handoff`)
# --------------------------------------------------------------------------
echo "[moorpost] step 6: /etc/moorpost/env skeleton"
mkdir -p /etc/moorpost
if [ ! -f /etc/moorpost/env ]; then
    : > /etc/moorpost/env
fi
chmod 0600 /etc/moorpost/env

{{.IdleMonitorInstall}}
# --------------------------------------------------------------------------
# Done
# --------------------------------------------------------------------------
echo "[moorpost] bootstrap complete at $(date -u +%FT%TZ)"
echo "[moorpost] project tree: $PROJECT_DIR"
echo "[moorpost] symlink:      $LOCAL_ABS_PATH -> $PROJECT_DIR"
